# Database
POSTGRES_USER=dashuser
POSTGRES_PASSWORD=dashpass
POSTGRES_DB=dashboard_avocado
DATABASE_URL=postgresql://dashuser:dashpass@localhost:5432/dashboard_avocado

# Server
PORT=5000
NODE_ENV=production

# JWT (REQUIRED — change this to a long random secret in production)
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRE=7d

# CORS
CORS_ORIGIN=http://localhost:3000
CORS_PUBLIC=false

# App
APP_NAME=Dashboard Avocado Backend
APP_VERSION=2.0.0

# Cloudinary (file uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Resend (transactional email)
RESEND_API_KEY=
FROM_EMAIL=noreply@avocadodashboard.com

# Frontend URL (used in password reset emails)
FRONTEND_URL=http://localhost:3000
