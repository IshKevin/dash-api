# Database
POSTGRES_USER=dashuser
POSTGRES_PASSWORD=dashpass
POSTGRES_DB=dashboard_avocado
DATABASE_URL=postgresql://dashuser:dashpass@localhost:5432/dashboard_avocado

# Server
PORT=5000
NODE_ENV=production

# JWT (REQUIRED — change this to a long random secret in production)
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRE=7d

# CORS
CORS_ORIGIN=http://localhost:3000
CORS_PUBLIC=false

# App
APP_NAME=Dashboard Avocado Backend
APP_VERSION=2.0.0

# MinIO (S3-compatible object storage for file uploads)
# MINIO_ENDPOINT/PORT are the internal address the API connects to (use the
# "minio" service hostname under docker-compose). MINIO_PUBLIC_URL is the
# externally-reachable base URL used to build download links — set this to
# your real public MinIO/CDN domain in production.
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=avocado-dashboard
MINIO_USE_SSL=false
MINIO_PUBLIC_URL=http://localhost:9000

# Resend (transactional email)
RESEND_API_KEY=
FROM_EMAIL=noreply@avocadodashboard.com

# Africa's Talking (SMS) — leave blank until you have credentials; SMS sends
# are silently skipped (logged, not fatal) while unconfigured, same as email
# behaves without RESEND_API_KEY.
AFRICASTALKING_USERNAME=
AFRICASTALKING_API_KEY=
AFRICASTALKING_SENDER_ID=

# Frontend URL (used in password reset emails)
FRONTEND_URL=http://localhost:3000
